---
---

<section class="relative overflow-hidden border-b border-border/30">
  <!-- Gradient orbs background -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute -top-40 left-1/4 h-125 w-125 rounded-full bg-primary/10 blur-[120px]"
    >
    </div>
    <div
      class="absolute -bottom-20 right-1/4 h-100 w-100 rounded-full bg-primary/5 blur-[100px]"
    >
    </div>
  </div>

  <div
    class="relative mx-auto grid max-w-7xl items-center gap-12 px-4 py-20 sm:px-6 md:py-28 lg:grid-cols-2 lg:gap-16 lg:px-8 lg:py-32"
  >
    <!-- Copy -->
    <div class="flex flex-col gap-6">
      <div
        class="inline-flex w-fit items-center gap-2 rounded-full border border-border/50 bg-muted/50 px-4 py-1.5 text-xs font-medium text-muted-foreground"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        Infraestructura cloud de nivel empresarial
      </div>

      <h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
        La infraestructura cloud que
        <span class="bg-linear-to-r from-primary to-emerald-400 bg-clip-text text-transparent">
          tu empresa necesita
        </span>
        para crecer
      </h1>

      <p class="max-w-xl text-lg leading-relaxed text-muted-foreground">
        Servidores VPS, almacenamiento, hosting y cómputo escalable para PYMES.
        Despliega en minutos, escala sin límites y paga solo por lo que usas.
      </p>

      <div class="flex flex-wrap items-center gap-3 pt-2">
        <a
          href="#precios"
          class="inline-flex h-11 items-center justify-center rounded-lg bg-primary px-6 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-all hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/30"
          id="hero-cta-plans"
        >
          Ver planes
          <svg
            class="ml-2 h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
        <a
          href="#contacto"
          class="inline-flex h-11 items-center justify-center rounded-lg border border-border px-6 text-sm font-medium text-foreground transition-colors hover:bg-muted"
          id="hero-cta-advisor"
        >
          Hablar con un asesor
        </a>
      </div>

      <!-- Quick stats -->
      <div class="mt-4 flex flex-wrap gap-8 border-t border-border/50 pt-6">
        <div>
          <p class="text-2xl font-bold">99.9%</p>
          <p class="text-xs text-muted-foreground">Uptime garantizado</p>
        </div>
        <div>
          <p class="text-2xl font-bold">+2,500</p>
          <p class="text-xs text-muted-foreground">Empresas activas</p>
        </div>
        <div>
          <p class="text-2xl font-bold">24/7</p>
          <p class="text-xs text-muted-foreground">Soporte técnico</p>
        </div>
      </div>
    </div>

    <!-- Visual: abstract cloud infrastructure SVG -->
    <div class="hidden lg:flex lg:items-center lg:justify-center" aria-hidden="true">
      <div class="relative">
        <!-- Glow behind -->
        <div
          class="absolute inset-0 rounded-3xl bg-linear-to-br from-primary/20 to-transparent blur-2xl"
        >
        </div>
        <svg
          viewBox="0 0 480 400"
          fill="none"
          class="relative h-auto w-full max-w-md"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Server rack base -->
          <rect x="140" y="200" width="200" height="160" rx="12" fill="currentColor" class="text-muted/40" />
          <rect x="140" y="200" width="200" height="160" rx="12" stroke="currentColor" class="text-border" stroke-width="1" />

          <!-- Server slots -->
          <rect x="160" y="220" width="160" height="28" rx="4" fill="currentColor" class="text-muted/60" />
          <rect x="160" y="258" width="160" height="28" rx="4" fill="currentColor" class="text-muted/60" />
          <rect x="160" y="296" width="160" height="28" rx="4" fill="currentColor" class="text-muted/60" />
          <rect x="160" y="334" width="160" height="14" rx="4" fill="currentColor" class="text-muted/60" />

          <!-- Status LEDs -->
          <circle cx="176" cy="234" r="3" fill="#34d399" />
          <circle cx="188" cy="234" r="3" fill="#34d399" />
          <circle cx="200" cy="234" r="3" fill="#34d399" opacity="0.4" />

          <circle cx="176" cy="272" r="3" fill="#34d399" />
          <circle cx="188" cy="272" r="3" fill="#34d399" />
          <circle cx="200" cy="272" r="3" fill="#34d399" />

          <circle cx="176" cy="310" r="3" fill="#34d399" />
          <circle cx="188" cy="310" r="3" fill="#fbbf24" />
          <circle cx="200" cy="310" r="3" fill="#34d399" opacity="0.4" />

          <!-- Cloud shape -->
          <path
            d="M180 160 C180 120, 220 100, 250 110 C260 80, 310 80, 320 110 C350 100, 380 120, 370 150 C400 160, 390 190, 360 190 L190 190 C160 190, 150 170, 180 160Z"
            fill="currentColor"
            class="text-primary/20"
            stroke="currentColor"
            stroke-width="1.5"
          />
          <path
            d="M180 160 C180 120, 220 100, 250 110 C260 80, 310 80, 320 110 C350 100, 380 120, 370 150 C400 160, 390 190, 360 190 L190 190 C160 190, 150 170, 180 160Z"
            stroke="currentColor"
            class="text-primary"
            stroke-width="1.5"
            fill="none"
          />

          <!-- Connection lines -->
          <line x1="240" y1="190" x2="240" y2="200" stroke="currentColor" class="text-primary/60" stroke-width="1.5" stroke-dasharray="3 3" />
          <line x1="280" y1="190" x2="280" y2="200" stroke="currentColor" class="text-primary/60" stroke-width="1.5" stroke-dasharray="3 3" />

          <!-- Floating nodes -->
          <circle cx="100" cy="140" r="20" fill="currentColor" class="text-muted/30" stroke="currentColor" stroke-width="1" />
          <circle cx="100" cy="140" r="6" fill="currentColor" class="text-primary/60" />
          <line x1="120" y1="140" x2="180" y2="160" stroke="currentColor" class="text-border" stroke-width="1" stroke-dasharray="4 4" />

          <circle cx="400" cy="130" r="20" fill="currentColor" class="text-muted/30" stroke="currentColor" stroke-width="1" />
          <circle cx="400" cy="130" r="6" fill="currentColor" class="text-primary/60" />
          <line x1="380" y1="130" x2="340" y2="150" stroke="currentColor" class="text-border" stroke-width="1" stroke-dasharray="4 4" />

          <!-- Upload / download arrows -->
          <path d="M260 130 L260 115 L252 123 M260 115 L268 123" stroke="currentColor" class="text-primary" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M290 130 L290 145 L282 137 M290 145 L298 137" stroke="currentColor" class="text-primary" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </div>
  </div>
</section>
