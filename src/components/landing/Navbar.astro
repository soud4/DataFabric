---
---

<nav
  class="sticky top-0 z-50 w-full border-b border-border/50 bg-background/80 backdrop-blur-xl"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5" aria-label="DataFabric inicio">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary-foreground"
        >
          <path d="M4 6l8-4 8 4" />
          <path d="M4 6v8l8 4" />
          <path d="M20 6v8l-8 4" />
          <path d="M4 10l8 4 8-4" />
        </svg>
      </div>
      <span class="text-lg font-bold tracking-tight">DataFabric</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-1 md:flex">
      <!-- Services dropdown -->
      <div class="group relative">
        <button
          class="flex items-center gap-1 rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
          aria-haspopup="true"
        >
          Servicios
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-transform group-hover:rotate-180">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </button>

        <!-- Dropdown -->
        <div class="pointer-events-none absolute left-1/2 top-full -translate-x-1/2 pt-2 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:opacity-100">
          <div class="w-80 rounded-xl border border-border/50 bg-card/95 p-2 shadow-xl shadow-black/10 backdrop-blur-xl">
            <a href="/servicios/vps" class="flex items-start gap-3 rounded-lg p-3 transition-colors hover:bg-muted">
              <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/></svg>
              </div>
              <div>
                <span class="text-sm font-semibold">VPS</span>
                <p class="text-xs text-muted-foreground">Servidores virtuales con recursos dedicados</p>
              </div>
            </a>
            <a href="/servicios/cloud-storage" class="flex items-start gap-3 rounded-lg p-3 transition-colors hover:bg-muted">
              <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg>
              </div>
              <div>
                <span class="text-sm font-semibold">Cloud Storage</span>
                <p class="text-xs text-muted-foreground">Almacenamiento S3-compatible y seguro</p>
              </div>
            </a>
            <a href="/servicios/hosting" class="flex items-start gap-3 rounded-lg p-3 transition-colors hover:bg-muted">
              <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div>
                <span class="text-sm font-semibold">Hosting</span>
                <p class="text-xs text-muted-foreground">Hosting web con SSL, CDN y backups</p>
              </div>
            </a>
            <a href="/servicios/servidores-dedicados" class="flex items-start gap-3 rounded-lg p-3 transition-colors hover:bg-muted">
              <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01"/><path d="M10 8h.01"/></svg>
              </div>
              <div>
                <span class="text-sm font-semibold">Servidores dedicados</span>
                <p class="text-xs text-muted-foreground">Hardware exclusivo de alto rendimiento</p>
              </div>
            </a>
            <a href="/servicios/cloud-computing" class="flex items-start gap-3 rounded-lg p-3 transition-colors hover:bg-muted">
              <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
              </div>
              <div>
                <span class="text-sm font-semibold">Cloud Computing</span>
                <p class="text-xs text-muted-foreground">Contenedores, K8s y auto-scaling</p>
              </div>
            </a>
          </div>
        </div>
      </div>

      <a href="/#precios" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">
        Precios
      </a>
      <a href="/#como-funciona" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">
        Cómo funciona
      </a>
      <a href="/#faq" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">
        FAQ
      </a>
    </div>

    <!-- CTA + Mobile toggle -->
    <div class="flex items-center gap-3">
      <a
        href="/#precios"
        class="hidden rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80 sm:inline-flex"
      >
        Empezar ahora
      </a>
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border/50 bg-background/95 backdrop-blur-xl md:hidden"
  >
    <div class="flex flex-col gap-1 px-4 py-3">
      <p class="px-3 pt-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground">Servicios</p>
      <a href="/servicios/vps" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">VPS</a>
      <a href="/servicios/cloud-storage" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">Cloud Storage</a>
      <a href="/servicios/hosting" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">Hosting</a>
      <a href="/servicios/servidores-dedicados" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">Servidores dedicados</a>
      <a href="/servicios/cloud-computing" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">Cloud Computing</a>

      <div class="my-2 h-px bg-border/50"></div>

      <a href="/#precios" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">Precios</a>
      <a href="/#como-funciona" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">Cómo funciona</a>
      <a href="/#faq" class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:text-foreground">FAQ</a>

      <a
        href="/#precios"
        class="mt-2 rounded-md bg-primary px-4 py-2 text-center text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/80"
      >
        Empezar ahora
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn")
  const menu = document.getElementById("mobile-menu")
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden")
    menu?.classList.toggle("hidden")
    btn.setAttribute("aria-expanded", String(!isOpen))
  })
</script>
