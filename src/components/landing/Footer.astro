---
const currentYear = new Date().getFullYear()

const footerLinks = [
  {
    title: "Servicios",
    links: [
      { label: "VPS", href: "/servicios/vps" },
      { label: "Cloud Storage", href: "/servicios/cloud-storage" },
      { label: "Hosting web", href: "/servicios/hosting" },
      { label: "Servidores dedicados", href: "/servicios/servidores-dedicados" },
      { label: "Cloud Computing", href: "/servicios/cloud-computing" },
    ],
  },
  {
    title: "Empresa",
    links: [
      { label: "Precios", href: "/#precios" },
      { label: "Soporte", href: "/#contacto" },
      { label: "Blog", href: "#" },
      { label: "Status", href: "#" },
      { label: "Contacto", href: "/#contacto" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Aviso legal", href: "#" },
      { label: "Privacidad", href: "#" },
      { label: "Términos de servicio", href: "#" },
      { label: "SLA", href: "#" },
      { label: "Cookies", href: "#" },
    ],
  },
]
---

<footer class="border-t border-border/30 bg-muted/5 py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-5">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="mb-4 flex items-center gap-2.5" aria-label="DataFabric">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary-foreground"
            >
              <path d="M4 6l8-4 8 4" />
              <path d="M4 6v8l8 4" />
              <path d="M20 6v8l-8 4" />
              <path d="M4 10l8 4 8-4" />
            </svg>
          </div>
          <span class="text-lg font-bold tracking-tight">DataFabric</span>
        </a>
        <p class="mb-6 max-w-sm text-sm leading-relaxed text-muted-foreground">
          Infraestructura cloud de alto rendimiento para empresas que necesitan crecer sin
          complicaciones. Servidores VPS, hosting, almacenamiento y cómputo escalable.
        </p>
        <!-- Social icons -->
        <div class="flex gap-3">
          {
            [
              {
                label: "Twitter",
                icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
              },
              {
                label: "LinkedIn",
                icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
              },
              {
                label: "GitHub",
                icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>`,
              },
            ].map((social) => (
              <a
                href="#"
                class="flex h-9 w-9 items-center justify-center rounded-lg border border-border/50 text-muted-foreground transition-all hover:border-border hover:text-foreground"
                aria-label={social.label}
              >
                <Fragment set:html={social.icon} />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Link columns -->
      {
        footerLinks.map((col) => (
          <div>
            <h3 class="mb-4 text-sm font-semibold">{col.title}</h3>
            <ul class="flex flex-col gap-2.5">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border/30 pt-8 sm:flex-row">
      <p class="text-xs text-muted-foreground">
        © {currentYear} DataFabric. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs text-muted-foreground transition-colors hover:text-foreground">
          Privacidad
        </a>
        <a href="#" class="text-xs text-muted-foreground transition-colors hover:text-foreground">
          Términos
        </a>
        <a href="#" class="text-xs text-muted-foreground transition-colors hover:text-foreground">
          Cookies
        </a>
      </div>
    </div>
  </div>
</footer>
