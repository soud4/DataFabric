---
---

<section id="contacto" class="relative overflow-hidden border-y border-border/30 py-20 lg:py-28">
  <!-- Background glow -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute left-1/2 top-1/2 h-100 w-150 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-[120px]"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div
      class="mb-4 inline-flex items-center rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
    >
      Comienza hoy
    </div>

    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
      Tu infraestructura del futuro
      <span class="bg-linear-to-r from-primary to-emerald-400 bg-clip-text text-transparent">
        empieza aquí
      </span>
    </h2>

    <p class="mx-auto mt-5 max-w-xl text-lg text-muted-foreground">
      Más de 2,500 empresas ya confían en DataFabric. Únete y despliega tu infraestructura cloud en
      menos de 5 minutos.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#precios"
        class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-sm font-semibold text-primary-foreground shadow-xl shadow-primary/25 transition-all hover:bg-primary/90 hover:shadow-2xl hover:shadow-primary/30"
        id="cta-final-contract"
      >
        Contratar ahora
        <svg
          class="ml-2 h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>

      <a
        href="mailto:ventas@datafabric.cloud"
        class="inline-flex h-12 items-center justify-center rounded-lg border border-border px-8 text-sm font-medium text-foreground transition-colors hover:bg-muted"
        id="cta-final-call"
      >
        Agendar una llamada
      </a>
    </div>

    <p class="mt-6 text-xs text-muted-foreground">
      Sin compromiso · Sin tarjeta de crédito · Migración gratuita
    </p>
  </div>
</section>
