---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/landing/Navbar.astro"
import ServiceHero from "@/components/services/ServiceHero.astro"
import SpecsGrid from "@/components/services/SpecsGrid.astro"
import ServiceFeatures from "@/components/services/ServiceFeatures.astro"
import UseCases from "@/components/services/UseCases.astro"
import PlanCalculator from "@/components/services/PlanCalculator.tsx"
import CtaFinal from "@/components/landing/CtaFinal.astro"
import Footer from "@/components/landing/Footer.astro"

const plans = [
  {
    name: "VPS Starter",
    price: "$14",
    popular: false,
    specs: [
      { label: "vCPUs", value: "1 core" },
      { label: "RAM", value: "2 GB DDR5" },
      { label: "Almacenamiento", value: "40 GB SSD" },
      { label: "Transferencia", value: "1 TB" },
      { label: "IPv4 dedicada", value: "1" },
      { label: "Backups", value: "Semanales" },
      { label: "Soporte", value: "Email" },
    ],
  },
  {
    name: "VPS Performance",
    price: "$49",
    popular: true,
    specs: [
      { label: "vCPUs", value: "4 cores" },
      { label: "RAM", value: "8 GB DDR5" },
      { label: "Almacenamiento", value: "160 GB NVMe" },
      { label: "Transferencia", value: "4 TB" },
      { label: "IPv4 dedicada", value: "2" },
      { label: "Backups", value: "Diarios" },
      { label: "Soporte", value: "Prioritario 24/7" },
    ],
  },
  {
    name: "VPS Enterprise",
    price: "$129",
    popular: false,
    specs: [
      { label: "vCPUs", value: "8 cores" },
      { label: "RAM", value: "32 GB DDR5" },
      { label: "Almacenamiento", value: "400 GB NVMe" },
      { label: "Transferencia", value: "10 TB" },
      { label: "IPv4 dedicada", value: "4" },
      { label: "Backups", value: "Continuos" },
      { label: "Soporte", value: "Dedicado + SLA" },
    ],
  },
]

const features = [
  { title: "Root access completo", description: "Control total sobre tu servidor con acceso SSH y permisos root.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>` },
  { title: "SSD NVMe", description: "Almacenamiento ultra-rápido con velocidades de lectura de hasta 7,000 MB/s.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="m13 2-2 10h6l-8 10 2-10H5l8-10z"/></svg>` },
  { title: "Red privada", description: "Conecta tus VPS entre sí con una red interna de hasta 10 Gbps sin costo extra.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 2v6"/><path d="M15 2v6"/><path d="M12 17v5"/><path d="M5 8h14"/><path d="M3.5 14h17"/></svg>` },
  { title: "Snapshots ilimitados", description: "Crea snapshots instantáneos de tu servidor para restaurar en segundos.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="m21 15-5-5L5 21"/></svg>` },
  { title: "Múltiples SO", description: "Ubuntu, Debian, CentOS, AlmaLinux, Windows Server y más disponibles.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>` },
  { title: "API REST completa", description: "Automatiza la gestión de tus VPS con nuestra API documentada.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="m16 18 6-6-6-6"/><path d="m8 6-6 6 6 6"/></svg>` },
  { title: "Firewall configurable", description: "Reglas de firewall personalizables desde el panel, sin configuración manual.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>` },
  { title: "Monitoreo incluido", description: "Gráficas de CPU, RAM, disco y red en tiempo real desde tu panel.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>` },
]

const useCases = [
  { title: "Aplicaciones web", description: "Despliega apps en Node.js, Python, PHP, Ruby o cualquier stack con control total.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>` },
  { title: "Bases de datos", description: "MySQL, PostgreSQL, MongoDB, Redis — con almacenamiento NVMe para consultas ultrarrápidas.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>` },
  { title: "Entornos de desarrollo", description: "Crea ambientes de staging y QA idénticos a producción en minutos.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="m16 18 6-6-6-6"/><path d="m8 6-6 6 6 6"/></svg>` },
  { title: "Gaming servers", description: "Latencia baja y CPU dedicada para servidores de Minecraft, Valheim, ARK y más.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h4"/><path d="M8 10v4"/><circle cx="16" cy="10" r="1" fill="currentColor"/><circle cx="18" cy="14" r="1" fill="currentColor"/></svg>` },
  { title: "VPN y proxy", description: "Configura tu propio servidor VPN con WireGuard o OpenVPN para acceso seguro.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>` },
  { title: "CI/CD Pipelines", description: "Ejecuta runners de GitLab CI, GitHub Actions o Jenkins con recursos dedicados.", icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>` },
]
---

<Layout
  title="VPS - Servidores Virtuales Privados | DataFabric"
  description="Servidores VPS con SSD NVMe, root access y escalado instantáneo. Desde $14/mes. Aprovisionamiento en menos de 60 segundos."
>
  <Navbar />
  <main>
    <ServiceHero
      title="VPS — Servidores Virtuales Privados"
      subtitle="Potencia dedicada, flexibilidad total y despliegue en segundos"
      description="Servidores virtuales con recursos garantizados, almacenamiento NVMe ultra-rápido y root access completo. Escala CPU, RAM y disco cuando lo necesites, sin reiniciar ni interrumpir tus servicios."
      badgeText="VPS Cloud"
    />
    <SpecsGrid plans={plans} />
    <PlanCalculator client:visible serviceType="vps" />
    <ServiceFeatures features={features} title="Todo incluido en tu VPS" subtitle="Cada VPS viene con herramientas enterprise, sin costo adicional." />
    <UseCases useCases={useCases} title="Casos de uso" subtitle="Nuestros VPS son la base de miles de proyectos." />
    <CtaFinal />
  </main>
  <Footer />
</Layout>
