---
import Layout from "@/layouts/main.astro"
import Navbar from "@/components/landing/Navbar.astro"
import Hero from "@/components/landing/Hero.astro"
import TrustBar from "@/components/landing/TrustBar.astro"
import Stats from "@/components/landing/Stats.astro"
import Services from "@/components/landing/Services.astro"
import WhyDataFabric from "@/components/landing/WhyDataFabric.astro"
import Pricing from "@/components/landing/Pricing.astro"
import HowItWorks from "@/components/landing/HowItWorks.astro"
import Timeline from "@/components/landing/Timeline.astro"
import Partners from "@/components/landing/Partners.astro"
import Testimonials from "@/components/landing/Testimonials.astro"
import FaqSection from "@/components/landing/FaqSection.tsx"
import CtaFinal from "@/components/landing/CtaFinal.astro"
import Footer from "@/components/landing/Footer.astro"
---

<Layout
  title="DataFabric — Infraestructura Cloud para Empresas | VPS, Hosting, Cloud Computing"
  description="Servidores VPS, almacenamiento en la nube, hosting y servidores dedicados para PYMES. Alta disponibilidad 99.9%, soporte 24/7 y precios desde $5/mes."
>
  <Navbar />

  <main>
    <Hero />
    <TrustBar />
    <Stats />
    <Services />
    <WhyDataFabric />
    <Pricing />
    <HowItWorks />
    <Timeline />
    <Partners />
    <Testimonials />
    <FaqSection client:visible />
    <CtaFinal />
  </main>

  <Footer />
</Layout>
